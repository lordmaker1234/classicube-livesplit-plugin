{
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [{ "breaking": true, "release": "minor" }]
      }
    ],
    [
      "@semantic-release/exec",
      {
        "successCmd": "gh release edit ${nextRelease.gitTag} --prerelease"
      }
    ]
  ]
}
